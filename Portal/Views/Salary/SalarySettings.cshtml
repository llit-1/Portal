@model Portal.Controllers.SalaryController.SalarySettingsBaseTable

@{
    var items = Model?.Items ?? new System.Collections.Generic.List<Portal.Controllers.SalaryController.BaseTableItem>();
    var jobTitles = Model?.jobTitles ?? new System.Collections.Generic.List<Portal.Models.MSSQL.Personality.JobTitle>();
    var locations = Model?.Locations ?? new System.Collections.Generic.List<Portal.Models.MSSQL.Location.Location>();
    var freeRules = Model?.FreeRules ?? new System.Collections.Generic.List<Portal.Controllers.SalaryController.SalaryRules>();
}

<div class="salary_wrapper">
    <div class="filter-block">

        <div class="salary-back back-hover" id="back">
            <label class="salary-back__label">Назад</label>
        </div>
        
        <div class="salary-filters-panel-wrapper">
            <div class="salary-filters-panel" role="tablist" aria-label="Вкладки настроек ставки">
                <button type="button" class="salary-tab-button is-active" data-tab="rate-constructor" aria-selected="true">Конструктор ставки</button>
                <button type="button" class="salary-tab-button" data-tab="special-locations" aria-selected="false">Особые локации</button>
                <button type="button" class="salary-tab-button" data-tab="experience-locations" aria-selected="false">Стаж</button>
                <button type="button" class="salary-tab-button" data-tab="production-locations" aria-selected="false">Выработка</button>
                <button type="button" class="salary-tab-button" data-tab="rule-create" aria-selected="false">Конструктор надбавок</button>
            </div>
        </div>
    </div>

    <div class="result-block">
        <div class="salary-result-panel is-active" data-tab-panel="rate-constructor">
            <div class="addButton-wrapper">
                <button class="addButton">Добавить</button>
            </div>

            <div class="salary-result__table-wrap">
                <table class="salary-result__table salary-rules-table">
                    <thead>
                        <tr>
                            <th>Основная должность</th>
                            <th>Категория из табеля</th>
                            <th>Ставка (без учета стажа и локации)</th>
                            <th>Стаж</th>
                            <th>Локация</th>
                            <th>Выработка</th>
                            <th>Период</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var rule in items)
                        {
                            <tr class="salary-settings-row"
                                data-rule-id="@rule.RuleId"
                                data-main-position="@(rule.MainJob?.Guid.ToString() ?? string.Empty)"
                                data-timesheet-category="@(rule.RealJob?.Guid.ToString() ?? string.Empty)"
                                data-base-rate="@(rule.BSM ?? string.Empty)"
                                data-has-experience="@(rule.EXK == "1" ? "1" : "0")"
                                data-has-location="@(rule.BAK == "1" ? "1" : "0")"
                                data-part-timer="@(rule.PartTimer ? "1" : "0")"
                                data-has-output="@(rule.PRK == "1" ? "1" : "0")"
                                data-period-from="@rule.Begin.ToString("yyyy-MM-dd")"
                                data-period-to="@rule.End.ToString("yyyy-MM-dd")">
                                <td data-label="Основная должность">@(rule.MainJob?.Name ?? "Парт-Таймер")</td>
                                <td data-label="Категория из табеля">@(rule.RealJob?.Name ?? "-")</td>
                                <td data-label="Ставка (без учета стажа и локации)">@(rule.BSM ?? "-")</td>
                                <td style="text-align: center;" data-label="Стаж">
                                    @if (rule.EXK == "1")
                                    {
                                        <span class="salary-flag is-plus" aria-label="Да">+</span>
                                    }
                                    else
                                    {
                                        <span class="salary-flag is-minus" aria-label="Нет">-</span>
                                    }
                                </td>
                                <td style="text-align: center;" data-label="Локация">
                                    @if (rule.BAK == "1")
                                    {
                                        <span class="salary-flag is-plus" aria-label="Да">+</span>
                                    }
                                    else
                                    {
                                        <span class="salary-flag is-minus" aria-label="Нет">-</span>
                                    }
                                </td>
                                <td style="text-align: center;" data-label="Выработка"><span class="salary-flag is-plus" aria-label="Да">
                                        @if (rule.PRK == "1")
                                        {
                                            <span class="salary-flag is-plus" aria-label="Да">+</span>
                                        }
                                        else
                                        {
                                            <span class="salary-flag is-minus" aria-label="Нет">-</span>
                                        }
                                </span></td>
                                <td data-label="Период">@rule.Begin.ToString("dd.MM.yyyy") - @rule.End.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                       
                    </tbody>
                </table>
            </div>
        </div>

        <div class="salary-result-panel"
             data-tab-panel="special-locations"
             data-tab-url="@Url.Action("SalarySettingsSpecialLocations", "Salary")"
             hidden>
        </div>

        <div class="salary-result-panel"
             data-tab-panel="experience-locations"
             data-tab-url="@Url.Action("SalarySettingsExperienceLocations", "Salary")"
             hidden>
        </div>

        <div class="salary-result-panel"
             data-tab-panel="production-locations"
             data-tab-url="@Url.Action("SalarySettingsProductionLocations", "Salary")"
             hidden>
        </div>

        <div class="salary-result-panel"
             data-tab-panel="rule-create"
             hidden>
            @await Html.PartialAsync("_SalarySettingsRuleCreate", freeRules)
        </div>


    </div>
</div>

<div class="salary-modal-overlay" id="salaryRuleModal" hidden>
    <div class="salary-modal" role="dialog" aria-modal="true" aria-labelledby="salaryRuleModalTitle">
        <div class="salary-modal__header">
            <h3 id="salaryRuleModalTitle" class="salary-modal__title">Добавление правила</h3>
            <button type="button" id="salaryRuleModalClose" class="salary-modal__close" aria-label="Закрыть">×</button>
        </div>

        <form id="salaryRuleForm" class="salary-modal__body">
            <input type="hidden" id="salaryRuleId" />

            <div class="salary-modal__field">
                <label for="salaryMainPosition">Основная должность</label>
                <select id="salaryMainPosition">
                    <option value=""></option>
                    @foreach(var job in jobTitles)
                    {
                        <option value="@job.Guid">@job.Name</option>
                    }
                </select>
            </div>

            <div class="salary-modal__field">
                <label for="salaryTimesheetCategory">Категория из табеля</label>
                <select id="salaryTimesheetCategory">
                    <option value=""></option>
                    @foreach (var job in jobTitles)
                    {
                        <option value="@job.Guid">@job.Name</option>
                    }
                </select>
            </div>

            <div class="salary-modal__field">
                <label for="salaryBaseRate">Ставка (без учета стажа и локации)</label>
                <input id="salaryBaseRate" type="number" step="1" min="0" required />
            </div>

            <div class="salary-modal__checks">
                <label><input id="salaryHasExperience" type="checkbox" /> Стаж</label>
                <label><input id="salaryHasLocation" type="checkbox" /> Локация</label>
                <label><input id="salaryHasOutput" type="checkbox" /> Выработка</label>
                <label><input id="salaryPartTimer" type="checkbox" /> Парт-таймер</label>
            </div>

            <div class="salary-modal__field">
                <label>Период</label>
                <div class="salary-modal__period">
                    <input id="salaryPeriodFrom" type="date" required />
                    <input id="salaryPeriodTo" type="date" required />
                </div>
            </div>

            <div class="salary-modal__actions">
                <button type="button" id="salaryRuleDeleteButton" class="salary-modal__btn salary-modal__btn--danger">Удалить</button>
                <button type="submit" id="salaryRuleSubmitButton" class="salary-modal__btn salary-modal__btn--primary">Создать</button>
            </div>
        </form>
    </div>
</div>

<div class="salary-modal-overlay" id="salaryLocationModal" hidden>
    <div class="salary-modal" role="dialog" aria-modal="true" aria-labelledby="salaryLocationModalTitle">
        <div class="salary-modal__header">
            <h3 id="salaryLocationModalTitle" class="salary-modal__title">Добавление особой локации</h3>
            <button type="button" id="salaryLocationModalClose" class="salary-modal__close" aria-label="Закрыть">Г—</button>
        </div>

        <form id="salaryLocationForm" class="salary-modal__body">
            <input type="hidden" id="salaryLocationRuleId" />

            <div class="salary-modal__field">
                <label for="salaryLocationSelect">ТТ</label>
                <select id="salaryLocationSelect" required>
                    <option value=""></option>
                    @foreach (var location in locations)
                    {
                        <option value="@location.RKCode">@location.Name</option>
                    }
                </select>
            </div>

            <div class="salary-modal__field">
                <label for="salaryLocationRate">Тариф</label>
                <input id="salaryLocationRate" type="number" step="1" min="0" required />
            </div>

            <div class="salary-modal__field">
                <label>Период</label>
                <div class="salary-modal__period">
                    <input id="salaryLocationPeriodFrom" type="date" required />
                    <input id="salaryLocationPeriodTo" type="date" required />
                </div>
            </div>

            <div class="salary-modal__actions">
                <button type="button" id="salaryLocationDeleteButton" class="salary-modal__btn salary-modal__btn--danger">Удалить</button>
                <button type="submit" id="salaryLocationSubmitButton" class="salary-modal__btn salary-modal__btn--primary">Создать</button>
            </div>
        </form>
    </div>
</div>

<div class="salary-modal-overlay" id="salaryExperienceModal" hidden>
    <div class="salary-modal" role="dialog" aria-modal="true" aria-labelledby="salaryExperienceModalTitle">
        <div class="salary-modal__header">
            <h3 id="salaryExperienceModalTitle" class="salary-modal__title">Добавление стажа</h3>
            <button type="button" id="salaryExperienceModalClose" class="salary-modal__close" aria-label="Закрыть">Г—</button>
        </div>

        <form id="salaryExperienceForm" class="salary-modal__body">
            <input type="hidden" id="salaryExperienceRuleId" />

            <div class="salary-modal__field">
                <label for="salaryExperienceMin">Стаж от</label>
                <input id="salaryExperienceMin" type="number" step="1" min="0" />
            </div>

            <div class="salary-modal__field">
                <label for="salaryExperienceMax">Стаж до</label>
                <input id="salaryExperienceMax" type="number" step="1" min="0" />
            </div>

            <div class="salary-modal__field">
                <label for="salaryExperienceBonus">Доплата</label>
                <input id="salaryExperienceBonus" type="number" step="1" min="0" required />
            </div>

            <div class="salary-modal__field">
                <label>Период</label>
                <div class="salary-modal__period">
                    <input id="salaryExperiencePeriodFrom" type="date" required />
                    <input id="salaryExperiencePeriodTo" type="date" required />
                </div>
            </div>

            <div class="salary-modal__actions">
                <button type="button" id="salaryExperienceDeleteButton" class="salary-modal__btn salary-modal__btn--danger">Удалить</button>
                <button type="submit" id="salaryExperienceSubmitButton" class="salary-modal__btn salary-modal__btn--primary">Создать</button>
            </div>
        </form>
    </div>
</div>

<div class="salary-modal-overlay" id="salaryProductionModal" hidden>
    <div class="salary-modal" role="dialog" aria-modal="true" aria-labelledby="salaryProductionModalTitle">
        <div class="salary-modal__header">
            <h3 id="salaryProductionModalTitle" class="salary-modal__title">Добавление выработки</h3>
            <button type="button" id="salaryProductionModalClose" class="salary-modal__close" aria-label="Закрыть">Г—</button>
        </div>

        <form id="salaryProductionForm" class="salary-modal__body">
            <input type="hidden" id="salaryProductionRuleId" />

            <div class="salary-modal__field">
                <label for="salaryProductionJobTitle">Категория из табеля</label>
                <select id="salaryProductionJobTitle" required>
                    <option value=""></option>
                    @foreach (var job in jobTitles)
                    {
                        <option value="@job.Guid">@job.Name</option>
                    }
                </select>
            </div>

            <div class="salary-modal__field">
                <label for="salaryProductionLong">Длительность</label>
                <input id="salaryProductionLong" type="number" step="1" min="0" required />
            </div>

            <div class="salary-modal__field">
                <label for="salaryProductionCount">Смены</label>
                <input id="salaryProductionCount" type="number" step="1" min="0" required />
            </div>

            <div class="salary-modal__field">
                <label for="salaryProductionPrm">Доплата</label>
                <input id="salaryProductionPrm" type="number" step="1" min="0" required />
            </div>

            <div class="salary-modal__field">
                <label>Период</label>
                <div class="salary-modal__period">
                    <input id="salaryProductionPeriodFrom" type="date" required />
                    <input id="salaryProductionPeriodTo" type="date" required />
                </div>
            </div>

            <div class="salary-modal__actions">
                <button type="button" id="salaryProductionDeleteButton" class="salary-modal__btn salary-modal__btn--danger">Удалить</button>
                <button type="submit" id="salaryProductionSubmitButton" class="salary-modal__btn salary-modal__btn--primary">Создать</button>
            </div>
        </form>
    </div>
</div>


<script>
    (() => {
        $("#PageHeader").text("Настройка правил расчета ставки");

        $('#back').unbind('click');
        $('#back').click(function () { location.hash = "#salary"; });

        const salaryWrapper = document.querySelector('.salary_wrapper');
        if (!salaryWrapper) {
            return;
        }

        const salarySettingsTabStorageKey = 'salary-settings-active-tab';
        const tabButtons = Array.from(salaryWrapper.querySelectorAll('.salary-tab-button[data-tab]'));
        const tabPanels = Array.from(salaryWrapper.querySelectorAll('.salary-result-panel[data-tab-panel]'));
        const constructorPanel = salaryWrapper.querySelector('[data-tab-panel="rate-constructor"]');
        const addButton = constructorPanel ? constructorPanel.querySelector('.addButton') : null;
        const tableBody = constructorPanel ? constructorPanel.querySelector('.salary-rules-table tbody') : null;

        const modal = document.getElementById('salaryRuleModal');
        const modalTitle = document.getElementById('salaryRuleModalTitle');
        const modalCloseButton = document.getElementById('salaryRuleModalClose');
        const form = document.getElementById('salaryRuleForm');
        const ruleIdInput = document.getElementById('salaryRuleId');
        const mainPositionSelect = document.getElementById('salaryMainPosition');
        const timesheetCategorySelect = document.getElementById('salaryTimesheetCategory');
        const baseRateInput = document.getElementById('salaryBaseRate');
        const hasExperienceCheckbox = document.getElementById('salaryHasExperience');
        const hasLocationCheckbox = document.getElementById('salaryHasLocation');
        const hasOutputCheckbox = document.getElementById('salaryHasOutput');
        const partTimerCheckbox = document.getElementById('salaryPartTimer');
        const periodFromInput = document.getElementById('salaryPeriodFrom');
        const periodToInput = document.getElementById('salaryPeriodTo');
        const submitButton = document.getElementById('salaryRuleSubmitButton');
        const deleteButton = document.getElementById('salaryRuleDeleteButton');

        const locationModal = document.getElementById('salaryLocationModal');
        const locationModalTitle = document.getElementById('salaryLocationModalTitle');
        const locationModalCloseButton = document.getElementById('salaryLocationModalClose');
        const locationForm = document.getElementById('salaryLocationForm');
        const locationRuleIdInput = document.getElementById('salaryLocationRuleId');
        const locationSelect = document.getElementById('salaryLocationSelect');
        const locationRateInput = document.getElementById('salaryLocationRate');
        const locationPeriodFromInput = document.getElementById('salaryLocationPeriodFrom');
        const locationPeriodToInput = document.getElementById('salaryLocationPeriodTo');
        const locationSubmitButton = document.getElementById('salaryLocationSubmitButton');
        const locationDeleteButton = document.getElementById('salaryLocationDeleteButton');

        const experienceModal = document.getElementById('salaryExperienceModal');
        const experienceModalTitle = document.getElementById('salaryExperienceModalTitle');
        const experienceModalCloseButton = document.getElementById('salaryExperienceModalClose');
        const experienceForm = document.getElementById('salaryExperienceForm');
        const experienceRuleIdInput = document.getElementById('salaryExperienceRuleId');
        const experienceMinInput = document.getElementById('salaryExperienceMin');
        const experienceMaxInput = document.getElementById('salaryExperienceMax');
        const experienceBonusInput = document.getElementById('salaryExperienceBonus');
        const experiencePeriodFromInput = document.getElementById('salaryExperiencePeriodFrom');
        const experiencePeriodToInput = document.getElementById('salaryExperiencePeriodTo');
        const experienceSubmitButton = document.getElementById('salaryExperienceSubmitButton');
        const experienceDeleteButton = document.getElementById('salaryExperienceDeleteButton');

        const productionModal = document.getElementById('salaryProductionModal');
        const productionModalTitle = document.getElementById('salaryProductionModalTitle');
        const productionModalCloseButton = document.getElementById('salaryProductionModalClose');
        const productionForm = document.getElementById('salaryProductionForm');
        const productionRuleIdInput = document.getElementById('salaryProductionRuleId');
        const productionJobTitleSelect = document.getElementById('salaryProductionJobTitle');
        const productionLongInput = document.getElementById('salaryProductionLong');
        const productionCountInput = document.getElementById('salaryProductionCount');
        const productionPrmInput = document.getElementById('salaryProductionPrm');
        const productionPeriodFromInput = document.getElementById('salaryProductionPeriodFrom');
        const productionPeriodToInput = document.getElementById('salaryProductionPeriodTo');
        const productionSubmitButton = document.getElementById('salaryProductionSubmitButton');
        const productionDeleteButton = document.getElementById('salaryProductionDeleteButton');

        let modalMode = 'create';
        let isFormLoading = false;
        let activeTabName = 'rate-constructor';
        let locationModalMode = 'create';
        let isLocationFormLoading = false;
        let experienceModalMode = 'create';
        let isExperienceFormLoading = false;
        let productionModalMode = 'create';
        let isProductionFormLoading = false;

        function getStoredActiveTabName() {
            try {
                const storedTabName = sessionStorage.getItem(salarySettingsTabStorageKey);
                if (storedTabName && tabButtons.some(button => button.dataset.tab === storedTabName)) {
                    return storedTabName;
                }
            } catch (error) {
                console.error('read salary settings active tab failed', error);
            }

            return 'rate-constructor';
        }

        function persistActiveTabName(tabName) {
            try {
                sessionStorage.setItem(salarySettingsTabStorageKey, tabName);
            } catch (error) {
                console.error('persist salary settings active tab failed', error);
            }
        }

        function setActiveTab(tabName) {
            activeTabName = tabName;
            persistActiveTabName(tabName);

            tabButtons.forEach(button => {
                const isActive = button.dataset.tab === tabName;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });

            tabPanels.forEach(panel => {
                const isActive = panel.dataset.tabPanel === tabName;
                panel.hidden = !isActive;
                panel.classList.toggle('is-active', isActive);
            });
        }

        function setDateRangeLimits(fromInput, toInput) {
            toInput.min = fromInput.value ? shiftIsoDate(fromInput.value, 1) : '';
            fromInput.max = toInput.value ? shiftIsoDate(toInput.value, -1) : '';
        }

        function normalizeDateRangeValues(fromInput, toInput, changedInput) {
            const from = fromInput.value;
            const to = toInput.value;

            if (from && to && from >= to) {
                if (changedInput === fromInput) {
                    toInput.value = shiftIsoDate(fromInput.value, 1);
                } else if (changedInput === toInput) {
                    fromInput.value = shiftIsoDate(toInput.value, -1);
                } else {
                    toInput.value = shiftIsoDate(fromInput.value, 1);
                }
            }

            setDateRangeLimits(fromInput, toInput);
        }

        async function loadTabPanelContent(tabName) {
            const panel = tabPanels.find(x => x.dataset.tabPanel === tabName);
            const requestUrl = panel ? panel.dataset.tabUrl : '';

            if (!panel || !requestUrl || tabName === 'rate-constructor') {
                return;
            }

            panel.innerHTML = '<div class="salary-result-panel__state">Загрузка...</div>';

            try {
                const response = await fetch(requestUrl, {
                    method: 'GET',
                    cache: 'no-store'
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                panel.innerHTML = await response.text();
                bindDynamicPanelInteractions(panel, tabName);
            } catch (error) {
                panel.innerHTML = '<div class="salary-result-panel__state salary-result-panel__state--error">Не удалось загрузить вкладку.</div>';
                console.error('load salary settings tab failed', error);
            }
        }

        function bindDynamicPanelInteractions(panel, tabName) {
            if (!panel) {
                return;
            }

            const addPanelButton = panel.querySelector('.salary-panel-add-button[data-tab-target]');
            if (addPanelButton) {
                addPanelButton.onclick = function (event) {
                    event.preventDefault();

                    if (tabName === 'special-locations') {
                        openCreateLocationModal();
                        return;
                    }

                    if (tabName === 'experience-locations') {
                        openCreateExperienceModal();
                        return;
                    }

                    if (tabName === 'production-locations') {
                        openCreateProductionModal();
                    }
                };
            }

            if (tabName === 'special-locations') {
                panel.querySelectorAll('.salary-location-row[data-rule-id]').forEach(row => {
                    row.onclick = function () {
                        openEditLocationModal(row);
                    };
                });
            }

            if (tabName === 'experience-locations') {
                panel.querySelectorAll('.salary-experience-row[data-rule-id]').forEach(row => {
                    row.onclick = function () {
                        openEditExperienceModal(row);
                    };
                });
            }

            if (tabName === 'production-locations') {
                panel.querySelectorAll('.salary-production-row[data-rule-id]').forEach(row => {
                    row.onclick = function () {
                        openEditProductionModal(row);
                    };
                });
            }
        }

        function shiftIsoDate(isoDate, days) {
            if (!isoDate) {
                return '';
            }

            const parts = isoDate.split('-').map(Number);
            if (parts.length !== 3 || parts.some(Number.isNaN)) {
                return '';
            }

            const date = new Date(parts[0], parts[1] - 1, parts[2]);
            date.setDate(date.getDate() + days);

            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');

            return `${year}-${month}-${day}`;
        }

        function isValidPeriod(from, to) {
            return !!from && !!to && from < to;
        }

        function setPeriodLimits() {
            periodToInput.min = periodFromInput.value ? shiftIsoDate(periodFromInput.value, 1) : '';
            periodFromInput.max = periodToInput.value ? shiftIsoDate(periodToInput.value, -1) : '';
        }

        function normalizePeriodValues(changedInput) {
            const from = periodFromInput.value;
            const to = periodToInput.value;

            if (from && to && from >= to) {
                if (changedInput === periodFromInput) {
                    periodToInput.value = shiftIsoDate(periodFromInput.value, 1);
                } else if (changedInput === periodToInput) {
                    periodFromInput.value = shiftIsoDate(periodToInput.value, -1);
                } else {
                    periodToInput.value = shiftIsoDate(periodFromInput.value, 1);
                }
            }

            setPeriodLimits();
        }

        function setModalMode(mode) {
            modalMode = mode;
            const isEdit = mode === 'edit';

            modalTitle.textContent = isEdit ? 'Редактирование правила' : 'Добавление правила';
            submitButton.textContent = isEdit ? 'Сохранить' : 'Создать';
            deleteButton.hidden = !isEdit;
        }

        function clearForm() {
            ruleIdInput.value = '';
            mainPositionSelect.value = '';
            timesheetCategorySelect.value = '';
            baseRateInput.value = '';
            hasExperienceCheckbox.checked = false;
            hasLocationCheckbox.checked = false;
            hasOutputCheckbox.checked = false;
            partTimerCheckbox.checked = false;
            periodFromInput.value = '';
            periodToInput.value = '';
            syncPartTimerState();
            setPeriodLimits();
        }

        function fillForm(data) {
            ruleIdInput.value = data.ruleId || '';
            mainPositionSelect.value = data.mainPosition || '';
            timesheetCategorySelect.value = data.timesheetCategory || '';
            baseRateInput.value = data.baseRate ?? '';
            hasExperienceCheckbox.checked = !!data.hasExperience;
            hasLocationCheckbox.checked = !!data.hasLocation;
            hasOutputCheckbox.checked = !!data.hasOutput;
            partTimerCheckbox.checked = !!data.partTimer;
            periodFromInput.value = data.periodFrom || '';
            periodToInput.value = data.periodTo || '';
            syncPartTimerState();
            normalizePeriodValues();
        }

        function syncPartTimerState() {
