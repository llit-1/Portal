        if (productionDeleteButton) {
            productionDeleteButton.addEventListener('click', async function () {
                if (productionModalMode !== 'edit') {
                    return;
                }

                if (!window.confirm('Точно удалить правило?')) {
                    return;
                }

                const ruleId = productionRuleIdInput.value;
                if (!ruleId) {
                    alert('Не найден id правила для удаления.');
                    return;
                }

                const requestUrl = `@Url.Action("DeleteItem", "Salary")?id=${encodeURIComponent(ruleId)}`;

                try {
                    setProductionFormLoading(true);

                    const response = await fetch(requestUrl, {
                        method: 'DELETE'
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    closeProductionModal();
                    await reloadActiveTabPanel();
                } catch (error) {
                    alert('Не удалось удалить правило выработки.');
                    console.error('delete production item failed', error);
                } finally {
                    setProductionFormLoading(false);
                }
            });
        }

    })();
</script>

