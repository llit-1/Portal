@model List<Portal.Controllers.SalaryController.ProductionTableItem>

@{
    var items = Model ?? new List<Portal.Controllers.SalaryController.ProductionTableItem>();
    var loadError = ViewBag.SalarySettingsTabLoadError as string;
}

<div class="addButton-wrapper">
    <button type="button" class="addButton salary-panel-add-button" data-tab-target="production-locations">Добавить</button>
</div>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="salary-result-panel__state salary-result-panel__state--error">@loadError</div>
}
else if (items.Count == 0)
{
    <div class="salary-result-panel__state">Данные не найдены.</div>
}
else
{
    <div class="salary-result__table-wrap">
        <table class="salary-result__table salary-editable-table">
            <thead>
                <tr>
                    <th>Категория из табеля</th>
                    <th>Длительность</th>
                    <th>Смены от</th>
                    <th>Смены до</th>
                    <th>Доплата</th>
                    <th>Период</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr class="salary-production-row"
                        data-rule-id="@item.RuleId"
                        data-job-title-guid="@(item.TimesheetJobTitle?.Guid.ToString() ?? string.Empty)"
                        data-timesheet-long="@item.TimesheetLong"
                        data-timesheet-count-start="@item.TimesheetCountStart"
                        data-timesheet-count-end="@item.TimesheetCountEnd"
                        data-prm="@item.PRM"
                        data-period-from="@item.Begin.ToString("yyyy-MM-dd")"
                        data-period-to="@item.End.ToString("yyyy-MM-dd")">
                        <td data-label="Категория из табеля">@(item.TimesheetJobTitle?.Name ?? "-")</td>
                        <td data-label="Длительность">от @item.TimesheetLong часов</td>
                        <td data-label="Смены от">@item.TimesheetCountStart</td>
                        <td data-label="Смены до">@item.TimesheetCountEnd</td>
                        <td data-label="Доплата">@item.PRM</td>
                        <td data-label="Период">@item.Begin.ToString("dd.MM.yyyy") - @item.End.ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
