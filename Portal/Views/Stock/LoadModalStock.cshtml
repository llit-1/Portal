@model Portal.Models.MSSQL.WarehouseCategories

<div id="stockCategoryModal" class="modal" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static" data-keyboard="false" style="display: none;">
    <div class="modal-dialog stock-category-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <div class="pull-right" style="margin-right:10px; height:10px">
                    <label class="ico md-close" style="margin-top: -2px" data-dismiss="modal"></label>
                </div>
                <h4 class="modal-title">@(Model.Name != null ? "Редактирование категории" : "Добавление категории")</h4>
            </div>
            <div class="modal-body">
                <div class="stock-category-modal">
                    <div class="stock-category-photo">
                        @if (Model.Img == null)
                        {
                            <img id="stock_category_img" src="/themes/clearmin/img/question.png" alt="" />
                        }
                        else
                        {
                            <img id="stock_category_img" src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Img)" alt="" />
                        }

                        <button type="button" id="stock_category_download" class="btn btn-default btn-sm stock-category-photo__button" onclick="selectImage()">Выбрать фото</button>
                    </div>

                    <div class="stock-category-data">
                        @if (Model.Name != null)
                        {
                            <p class="hidden" id="stock-category-parent">@Model.Parent</p>
                            <p class="hidden" id="stock-category-actual">@Model.Actual</p>
                            <p class="hidden" id="stock-category-img">@Model.Img</p>
                        }

                        <div class="form-group">
                            <label for="stock-category-name">Название категории</label>
                            <input id="stock-category-name" class="form-control" value="@Model.Name" />
                        </div>

                        @if (Model.Name != null)
                        {
                            <div class="stock-category-switch">
                                <span>Активность</span>
                                <div class="material-switch pull-right">
                                    <input class="slider addCategory"
                                           id="addCategory_@Model.Id"
                                           type="checkbox"
                                           @(Model.Actual == 1 ? "checked" : "")
                                           onclick="event.stopPropagation(); switchActive(@Model.Id, event);" />
                                    <label for="addCategory_@Model.Id" class="label-warning"></label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                @if (Model.Name != null)
                {
                    <button type="button" class="btn btn-sm btn-default" onclick="DeleteCategory(@Model.Id)">Удалить</button>
                    <button type="button" class="btn btn-sm btn-success" onclick="SaveCategory(@Model.Id)">Сохранить</button>
                }
                else
                {
                    <button type="button" class="btn btn-sm btn-success" onclick="SaveNewCategory()">Добавить</button>
                }
                <button type="button" class="btn btn-sm btn-default" data-dismiss="modal">Отмена</button>
            </div>
        </div>
    </div>
</div>

<style>
    .stock-category-dialog {
        width: 430px;
        max-width: calc(100vw - 30px);
    }

    .stock-category-modal {
        display: flex;
        flex-direction: row;
        gap: 14px;
        align-items: flex-start;
    }

    .stock-category-photo {
        width: 112px;
        min-width: 112px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: center;
    }

    .stock-category-photo > img {
        width: 100%;
        height: 112px;
        object-fit: contain;
        border-radius: 6px;
        background: #f5f5f5;
        padding: 8px;
        border: 1px solid #e5e5e5;
    }

    .stock-category-photo__button {
        width: 100%;
    }

    .stock-category-data {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 0;
    }

    .stock-category-data .form-group {
        margin-bottom: 0;
    }

    .stock-category-switch {
        display: flex;
        justify-content: space-between;
        align-items: start;
        padding-top: 2px;
        flex-direction: column;
        gap: 10px;
    }

    .stock-category-switch > span {
        font-family: "Akrobat-regular";
        font-weight: bold;
    }

    @@media (max-width: 767px) {
        .stock-category-modal {
            flex-direction: column;
        }

        .stock-category-photo {
            width: 100%;
            min-width: 100%;
        }

        .stock-category-photo > img {
            height: 140px;
        }
    }
</style>
