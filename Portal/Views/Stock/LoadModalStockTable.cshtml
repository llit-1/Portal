@model int

<div id="stockTableCreateModal" class="modal" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static" data-keyboard="false" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <div class="pull-right" style="margin-right:10px; height:10px">
                    <label class="ico md-close" style="margin-top: -2px" data-dismiss="modal"></label>
                </div>
                <h4 class="modal-title">Добавление подкатегории</h4>
            </div>
            <div class="modal-body">
                <div class="form-group" style="margin-bottom: 0;">
                    <label for="stock-table-input">Введите название</label>
                    <input id="stock-table-input" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-success" onclick="saveStockTableCategory(@Model)">Добавить</button>
                <button type="button" class="btn btn-sm btn-default" data-dismiss="modal">Отмена</button>
            </div>
        </div>
    </div>
</div>

<script>
    async function saveStockTableCategory(parentId) {
        const input = document.getElementById("stock-table-input");
        const name = input ? input.value.trim() : "";

        if (!name) {
            return;
        }

        const data = {
            Id: null,
            Name: name,
            Parent: parentId,
            Actual: 1,
            Img: null
        };

        $("#spinner").show();

        try {
            await fetch("/Stock/AddSubCategoryItem", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            if (typeof hideDynamicStockModal === "function") {
                hideDynamicStockModal();
            }

            const categoryIdElement = document.getElementById("categoryID");
            if (categoryIdElement) {
                await $(".stock").load("/Stock/StockTable?id=" + categoryIdElement.textContent.trim());
                return;
            }

            await $(".stock").load("/Stock/Stock");
        } finally {
            $("#spinner").hide();
        }
    }
</script>
