<!--кнопка изменить камеры-->
<script>
    function applySelectedNxLayout() {
        var selectedLayoutId = $('#selectedNxLayoutId').val();
        $('.nx-layout-item').removeClass('active');

        if (!selectedLayoutId) {
            $('#selectedNxLayoutName').text('');
            $('#selectedNxLayoutBlock').addClass('d-none');
            return;
        }

        var selectedLayout = $('.nx-layout-item[data-layout-id="' + selectedLayoutId + '"]').first();
        if (selectedLayout.length > 0) {
            selectedLayout.addClass('active');
            $('#selectedNxLayoutName').text(selectedLayout.data('layout-name'));
            $('#selectedNxLayoutBlock').removeClass('d-none');
        }
        else {
            $('#selectedNxLayoutName').text(selectedLayoutId);
            $('#selectedNxLayoutBlock').removeClass('d-none');
        }
    }

    function selectNxLayout(el) {
        var layoutId = $(el).data('layout-id');
        var layoutName = $(el).data('layout-name');
        var currentLayoutId = $('#selectedNxLayoutId').val();

        if (currentLayoutId && currentLayoutId === layoutId) {
            $('#selectedNxLayoutId').val('');
            $('#selectedNxLayoutName').text('');
            $('#selectedNxLayoutBlock').addClass('d-none');
            $('.nx-layout-item').removeClass('active');
        }
        else {
            $('#selectedNxLayoutId').val(layoutId ?? '');
            $('#selectedNxLayoutName').text(layoutName || layoutId || '');
            $('#selectedNxLayoutBlock').toggleClass('d-none', !layoutName && !layoutId);
            $('.nx-layout-item').removeClass('active');
            $(el).addClass('active');
        }

        SaveNxLayout();
    }

    function SaveNxLayout() {
        if (newTT) {
            return;
        }

        var tt = {};
        tt.id = hasSingleOldTt ? existingTtId : "0";
        tt.Guid = ttGuid;
        tt.attribute = "nxLayout";
        tt.nxLayout = $('#selectedNxLayoutId').val();

        var ttjsn = JSON.stringify(tt);
        ttjsn = ttjsn.replace(/ /g, "%bkspc%");

        $.ajax({
            type: "POST",
            url: '/Settings_TT/TTSave',
            data: { ttjsn: ttjsn },
            datatype: "text",
            success: function (result) {
                if (!result.ok) {
                    ShowModal('Редактор ТТ', result.data);
                }
            },
            error: function (error) {
                ShowModal('Редактор ТТ', error.responseText);
            }
        });
    }

    function filterNxLayouts(value) {
        var query = (value || '').toLowerCase();

        $('.nx-layout-item').each(function () {
            var name = ($(this).data('layout-name') || '').toString().toLowerCase();
            $(this).toggle(name.indexOf(query) >= 0);
        });
    }

    function CamEdit() {
        $("#camModal").modal("show");
        TTlayoutsPreview();
    }
</script>

